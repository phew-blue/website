---
const freelance = import.meta.env.PHEW_BLUE_FREELANCE === 'true'
const pathname = Astro.url.pathname
---
<nav class="nav">
  <a href="/" class="nav-logo">
    <svg viewBox="-49 -21 560 799" xmlns="http://www.w3.org/2000/svg" class="nav-symbol">
      <path fill-rule="evenodd" clip-rule="evenodd" d="m489.475 440.4 -347.53 209.645c-3.183 2.504 -7.148 4.07 -11.52 4.07a18.626 18.626 0 0 1 -18.637 -18.626c0 -7.043 3.997 -13.106 9.757 -16.278l348.626 -211.93a32.348 32.348 0 0 0 5.41 -4.252 30.287 30.287 0 0 0 0 -42.835 31.304 31.304 0 0 0 -6.026 -4.638L89.896 124.79a36 36 0 0 0 -16.461 -4.033 36.183 36.183 0 0 0 -36.183 36.162v401.708a18.626 18.626 0 1 1 -37.252 0V156.125C0 116.014 32.504 83.478 72.637 83.478c13.169 0 25.45 3.579 36.104 9.699l380.577 229.565c19.456 12.386 32.41 34.09 32.41 58.868 0 24.71 -12.887 46.362 -32.254 58.79m-433.591 202.09a18.626 18.626 0 1 1 0 37.252 18.626 18.626 0 0 1 -18.631 -18.616 18.626 18.626 0 0 1 18.631 -18.637" fill="#0092ca"/>
    </svg>
    <span class="nav-name">phew.blue</span>
  </a>
  <div class="nav-links">
    {freelance && <a href="/work" class:list={['nav-link', { active: pathname.startsWith('/work') }]}>Work</a>}
    {freelance && <a href="/#skills" class="nav-link">Skills</a>}
    <a href="/software" class:list={['nav-link', { active: pathname.startsWith('/software') }]}>Software</a>
    {freelance && <a href="/#about" class="nav-link">About</a>}
    <a href="/#contact" class:list={['nav-link', { active: pathname === '/#contact' }]}>Contact</a>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 56px;
    background: oklch(0.07 0.016 225 / 90%);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid oklch(1 0 0 / 8%);
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .nav-symbol { width: 22px; height: auto; }
  .nav-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 2px;
    color: oklch(0.93 0.008 220);
  }
  .nav-links { display: flex; gap: 2rem; align-items: center; }
  .nav-link {
    font-size: 13px;
    color: oklch(0.60 0.030 220);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-link:hover, .nav-link.active { color: oklch(0.93 0.008 220); }
</style>
