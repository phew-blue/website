---
import { personalInfo } from '../config/personal'
---
<section id="contact" class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Contact</span>
      <h2 class="section-title">Get in Touch</h2>
    </div>
    <div class="contact-links">
      <a href={`mailto:${personalInfo.email}`} class="contact-card">
        <span class="contact-icon">✉</span>
        <div>
          <div class="contact-type">Email</div>
          <div class="contact-value">{personalInfo.email}</div>
        </div>
      </a>
      <a href={personalInfo.linkedin} class="contact-card" target="_blank" rel="noopener">
        <span class="contact-icon">in</span>
        <div>
          <div class="contact-type">LinkedIn</div>
          <div class="contact-value">Robert Sumner</div>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .section { padding: 5rem 0 6rem; }
  .container { max-width: 900px; margin: 0 auto; padding: 0 2rem; }
  .section-header { margin-bottom: 2rem; }
  .section-label {
    display: block;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: oklch(0.70 0.12 218);
    margin-bottom: 0.5rem;
  }
  .section-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: oklch(0.93 0.008 220);
    margin: 0;
  }
  .contact-links { display: flex; gap: 1rem; flex-wrap: wrap; }
  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: oklch(0.12 0.022 222);
    border: 1px solid oklch(1 0 0 / 6%);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: border-color 0.15s;
    min-width: 220px;
  }
  .contact-card:hover { border-color: oklch(0.70 0.12 218 / 40%); }
  .contact-icon {
    font-size: 18px;
    color: oklch(0.70 0.12 218);
    width: 32px;
    text-align: center;
  }
  .contact-type { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: oklch(0.50 0.022 220); margin-bottom: 3px; }
  .contact-value { font-size: 13px; color: oklch(0.88 0.010 220); }
</style>
