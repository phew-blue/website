---
import { getCollection } from 'astro:content'
import { fetchRepoData } from '../lib/github'

const entries = await getCollection('software')
const repoData = await Promise.all(entries.map(e => fetchRepoData(e.data.repo)))

const LANG_COLORS: Record<string, string> = {
  TypeScript: '#3178c6',
  Go: '#00acd7',
  Python: '#3572a5',
}
---

<section id="software" class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Software</span>
      <h2 class="section-title">Open Source</h2>
    </div>
    <div class="software-list">
      {entries.map((entry, i) => {
        const gh = repoData[i]
        return (
          <div class="repo-row">
            <div class="repo-main">
              {gh.language && <span class="lang-dot" style={`background:${LANG_COLORS[gh.language] ?? '#888'}`} />}
              <span class="repo-name">{entry.data.displayName}</span>
              <span class="repo-desc">{gh.description ?? ''}</span>
            </div>
            <div class="repo-meta">
              {gh.release && <span class="release-pill">{gh.release.tag}</span>}
              {gh.release && (
                <span class="release-date">
                  {new Date(gh.release.publishedAt).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
                </span>
              )}
              <a href={`https://github.com/${entry.data.repo}`} class="gh-link" target="_blank" rel="noopener" aria-label="GitHub repository">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
                </svg>
              </a>
            </div>
          </div>
        )
      })}
    </div>
    <div class="section-footer">
      <a href="/software" class="view-all">View details →</a>
    </div>
  </div>
</section>

<style>
  .section { padding: 5rem 0; }
  .container { max-width: 900px; margin: 0 auto; padding: 0 2rem; }
  .section-header { margin-bottom: 2rem; }
  .section-label { display: block; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: oklch(0.70 0.12 218); margin-bottom: 0.5rem; }
  .section-title { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: oklch(0.93 0.008 220); margin: 0; }
  .software-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .repo-row {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    background: oklch(0.12 0.022 222); border: 1px solid oklch(1 0 0 / 6%);
    border-radius: 6px; padding: 0.875rem 1.25rem;
  }
  .repo-main { display: flex; align-items: center; gap: 0.625rem; flex: 1; min-width: 0; }
  .lang-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
  .repo-name { font-weight: 600; font-size: 13px; color: oklch(0.88 0.010 220); flex-shrink: 0; }
  .repo-desc { font-size: 11px; color: oklch(0.52 0.022 220); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .repo-meta { display: flex; align-items: center; gap: 0.625rem; flex-shrink: 0; }
  .release-pill {
    font-family: 'Courier New', monospace; font-size: 10px;
    background: oklch(0.70 0.12 218 / 12%); color: oklch(0.70 0.12 218);
    border: 1px solid oklch(0.70 0.12 218 / 20%); border-radius: 3px; padding: 2px 7px;
  }
  .release-date { font-size: 10px; color: oklch(0.45 0.020 220); }
  .gh-link {
    display: flex; align-items: center; justify-content: center;
    color: oklch(0.55 0.025 220); text-decoration: none;
    border: 1px solid oklch(1 0 0 / 8%); border-radius: 3px; padding: 4px 6px;
    width: 24px; height: 24px;
  }
  .gh-link:hover { color: oklch(0.93 0.008 220); border-color: oklch(0.70 0.12 218 / 40%); }
  .section-footer { margin-top: 1rem; text-align: right; }
  .view-all { font-size: 12px; color: oklch(0.70 0.12 218); text-decoration: none; }
</style>
